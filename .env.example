DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=example.com,www.example.com,EC2_PUBLIC_IP
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000

# Optional SMTP settings. Leave DJANGO_EMAIL_BACKEND unset for console email.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=

# Optional pixel collector integration.
PIXEL_SCRIPT_URL=
PIXEL_COLLECTOR_URL=
PIXEL_ID=px_123

# Collector-only setting, used when running collector_config.wsgi.
COLLECTOR_ALLOWED_ORIGINS=https://example.com,https://www.example.com
